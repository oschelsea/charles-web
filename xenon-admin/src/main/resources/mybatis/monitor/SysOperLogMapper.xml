<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xenon.project.monitor.mapper.SysOperLogMapper">
    <!-- 增加条件，规避全表删除修改拦截插件 -->
    <update id="cleanOperLog">
        delete from sys_oper_log where 1=1 and status = '0'
    </update>
</mapper>
